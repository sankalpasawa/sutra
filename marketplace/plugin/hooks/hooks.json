{
  "description": "Sutra governance hooks — depth-marker gate, estimation logging, version banners, + C3c token-compression bundle. Phase-1 activation adds: session-logger, artifact-check, estimation-enforcement, log-triage, log-skill-feedback, measurement-logger, compliance-tracker.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/update-banner.sh", "timeout": 3 },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/sessionstart-auto-activate.sh", "timeout": 10 },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-logger.sh", "timeout": 5 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/depth-marker-pretool.sh", "timeout": 5 },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/operationalization-check.sh", "timeout": 5 }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/rtk-auto-rewrite.sh", "timeout": 5 },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/codex-directive-gate.sh", "timeout": 5 }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/keys-in-env-vars.sh", "timeout": 5 },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/enforce-boundaries.sh", "timeout": 5 },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/codex-directive-gate.sh", "timeout": 5 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/posttool-counter.sh", "timeout": 5 }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/cascade-check.sh", "timeout": 5 },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/estimation-enforcement.sh", "timeout": 5 },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/artifact-check.sh", "timeout": 5 }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/completion-protocol-check.sh", "timeout": 5 }
        ]
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/posttool-mcp-compress.sh", "timeout": 10 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/reset-turn-markers.sh", "timeout": 3 },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/codex-directive-detect.sh", "timeout": 3 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/estimation-stop.sh", "timeout": 10 },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/flush-telemetry.sh", "timeout": 10 },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/estimation-collector.sh", "timeout": 15 },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-logger.sh", "timeout": 5 },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/log-triage.sh", "timeout": 5 },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/log-skill-feedback.sh", "timeout": 5 },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/measurement-logger.sh", "timeout": 5 },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/compliance-tracker.sh", "timeout": 10 }
        ]
      }
    ]
  }
}
