#!/bin/bash
# Sutra plugin — unified dispatcher (v1.4.0+)
# Claude Code auto-adds plugin bin/ to PATH, so `sutra <sub>` works as a bare
# command — one permission scope instead of per-script prompts.
#
# v1.4.0 — collapsed surface: start / status / update / uninstall are the
# four lifecycle verbs. push / onboard / go kept as internal aliases for
# backward-compat but no longer have slash-command front-ends.

set -u

SUTRA_BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUGIN_ROOT="$(dirname "$SUTRA_BIN_DIR")"
SCRIPTS_DIR="$PLUGIN_ROOT/scripts"

# v2.10.1 — Connectors preflight. Fresh `/plugin install sutra@marketplace`
# does NOT run `npm install` for nested package.json files, and does not
# install the `age` system binary. Both are required for the connectors
# subcommands (connect / connect-test / call). preflight_connectors()
# checks both, prints install instructions and exits non-zero if missing,
# OR runs `npm install --omit=dev` once if node_modules is the only gap.
preflight_connectors() {
  local CONNECTORS_DIR="$PLUGIN_ROOT/connectors"

  # Check 1 — `age` CLI binary. On macOS with brew available we auto-install
  # (user-scope, no sudo). On Linux/Windows we print instructions and exit;
  # auto-install via apt/scoop typically requires sudo or per-shell scoop init,
  # which we won't trigger from a Sutra subcommand.
  if ! command -v age >/dev/null 2>&1; then
    if [ "$(uname -s)" = "Darwin" ] && command -v brew >/dev/null 2>&1; then
      echo "Sutra Connectors: 'age' missing — installing via brew (one-time)..." >&2
      if ! brew install age >&2; then
        cat <<EOF >&2
brew install age failed. Install manually then re-run your sutra command:
  brew install age          # macOS
  https://github.com/FiloSottile/age/releases   (manual download)
EOF
        exit 1
      fi
      echo "✓ age installed." >&2
    else
      cat <<EOF >&2
Sutra Connectors require the 'age' CLI for credential encryption at rest.

Install:
  brew install age          # macOS
  apt install age           # Debian/Ubuntu
  pacman -S age             # Arch
  scoop install age         # Windows (scoop)

Or download: https://github.com/FiloSottile/age/releases

Then re-run your sutra command.
EOF
      exit 1
    fi
  fi

  # Check 2 — connectors node_modules. If missing OR partial (any of the
  # three runtime deps not resolved), run npm install --omit=dev once. We
  # deliberately use --omit=dev so vitest, typescript, etc. don't land on
  # client machines (~25 MB saved). Per-dep check (codex M2 master review
  # P2) protects against partial/interrupted installs that would otherwise
  # leave a present-but-broken node_modules tree and silently fail later.
  if [ ! -d "$CONNECTORS_DIR/node_modules" ] \
     || [ ! -d "$CONNECTORS_DIR/node_modules/yaml" ] \
     || [ ! -d "$CONNECTORS_DIR/node_modules/nanoid" ] \
     || [ ! -d "$CONNECTORS_DIR/node_modules/cockatiel" ]; then
    if ! command -v npm >/dev/null 2>&1; then
      cat <<EOF >&2
Sutra Connectors require Node.js (npm) for first-run dependency install.
Install Node ≥18 from https://nodejs.org/ then re-run your sutra command.
EOF
      exit 1
    fi
    echo "Sutra Connectors first-run: installing runtime deps (yaml, nanoid, cockatiel)..." >&2
    if ! ( cd "$CONNECTORS_DIR" && npm install --omit=dev --no-audit --no-fund --silent ) >&2; then
      cat <<EOF >&2
npm install failed in $CONNECTORS_DIR. Run manually:
  cd "$CONNECTORS_DIR" && npm install --omit=dev
EOF
      exit 1
    fi
    echo "✓ Connectors deps installed." >&2
  fi
}

SUBCMD="${1:-help}"
[ $# -gt 0 ] && shift

case "$SUBCMD" in
  # Primary lifecycle verbs (v1.4.0)
  start)
    exec bash "$SCRIPTS_DIR/start.sh" "$@"
    ;;
  status)
    exec bash "$SCRIPTS_DIR/status.sh" "$@"
    ;;
  connect)
    CONNECTORS_DIR="$PLUGIN_ROOT/connectors"
    [ -x "$CONNECTORS_DIR/scripts/connect.sh" ] || { echo "connectors module not installed" >&2; exit 1; }
    preflight_connectors
    exec bash "$CONNECTORS_DIR/scripts/connect.sh" "$@"
    ;;
  connect-test)
    CONNECTORS_DIR="$PLUGIN_ROOT/connectors"
    [ -f "$CONNECTORS_DIR/scripts/verify-connection.mjs" ] || { echo "connectors module not installed" >&2; exit 1; }
    preflight_connectors
    exec node "$CONNECTORS_DIR/scripts/verify-connection.mjs" "$@"
    ;;
  call)
    CONNECTORS_DIR="$PLUGIN_ROOT/connectors"
    [ -f "$CONNECTORS_DIR/scripts/call.mjs" ] || { echo "connectors module not installed" >&2; exit 1; }
    preflight_connectors
    exec node "$CONNECTORS_DIR/scripts/call.mjs" "$@"
    ;;
  update)
    echo "Refreshing marketplace + updating plugin..."
    claude plugin marketplace update sutra
    claude plugin update core@sutra
    ;;
  uninstall)
    echo "Uninstalling Sutra plugin..."
    claude plugin uninstall core@sutra
    case "${1:-}" in
      --purge)
        echo "Purging ~/.sutra..."
        rm -rf "$HOME/.sutra"
        ;;
    esac
    echo "Done."
    ;;

  # v2.0 — manual feedback channel (local-only, never transmits)
  feedback)
    exec bash "$SCRIPTS_DIR/feedback.sh" "$@"
    ;;

  # v2.1 — PEDAGOGY charter: interactive tutor
  learn)
    exec bash "$SCRIPTS_DIR/learn.sh" "$@"
    ;;

  # v2.1 — SECURITY charter: supply-chain integrity (SBOM)
  sbom)
    exec bash "$SCRIPTS_DIR/sbom.sh" "$@"
    ;;

  # Secondary — kept callable from bin/ for power users and shell helpers
  push)
    exec bash "$SCRIPTS_DIR/push.sh" "$@"
    ;;
  onboard)
    # Back-compat alias → start
    exec bash "$SCRIPTS_DIR/start.sh" "$@"
    ;;
  go)
    # Back-compat alias → start
    exec bash "$SCRIPTS_DIR/start.sh" "$@"
    ;;
  install-shell-helpers)
    exec bash "$SCRIPTS_DIR/install-shell-helpers.sh" "$@"
    ;;
  leak-audit)
    exec bash "$SCRIPTS_DIR/leak-audit.sh" "$@"
    ;;
  permissions)
    # Print the paste-ready JSON allowlist from PERMISSIONS.md (first json fence block).
    if [ -f "$PLUGIN_ROOT/PERMISSIONS.md" ]; then
      awk '/^```json$/{flag=1; next} /^```$/{if(flag){exit}} flag' "$PLUGIN_ROOT/PERMISSIONS.md"
    else
      echo "PERMISSIONS.md not found in plugin root ($PLUGIN_ROOT)" >&2
      exit 1
    fi
    ;;

  # ── Assistant Interaction Layer (v2.2.0+) ───────────────────────────
  # Default is OFF (founder directive 2026-04-27 — opt-in via positive flag).
  # Hard kill-switch files still win when present.
  enable)
    # sutra enable — opt in to running the assistant observer.
    # Order: check hard-disable conflicts FIRST so we never leave a stale
    # opt-in flag behind on the error path (codex review 2026-04-27).
    if [ -f "$HOME/.sutra-assistant-disabled" ]; then
      echo "⚠️  ~/.sutra-assistant-disabled is present and overrides enable."
      echo "   Remove it with: rm ~/.sutra-assistant-disabled"
      exit 1
    fi
    if [ -f "$HOME/.sutra-disabled" ]; then
      echo "⚠️  ~/.sutra-disabled (global Sutra kill) overrides enable."
      echo "   Remove it with: rm ~/.sutra-disabled"
      exit 1
    fi
    if [ -n "${SUTRA_ASSISTANT_DISABLED:-}" ]; then
      echo "note: SUTRA_ASSISTANT_DISABLED env is set; unset it in this shell to clear"
    fi
    # All clear — flip the opt-in flag.
    touch "$HOME/.sutra-assistant-enabled"
    echo "✅ Assistant enabled (~/.sutra-assistant-enabled created)"
    echo "   Next Stop event fires observer; events appended to state/assistants/<client_id>/events.jsonl"
    echo "   Disable: sutra disable     |     Status: sutra explain"
    ;;

  disable)
    # sutra disable — persistent off (zero tokens) by removing opt-in flag
    rm -f "$HOME/.sutra-assistant-enabled" 2>/dev/null
    echo "⏹️  Assistant disabled (~/.sutra-assistant-enabled removed)"
    echo "   Re-enable: sutra enable"
    ;;

  explain)
    EXP="$PLUGIN_ROOT/hooks/assistant-explain.sh"
    [ -x "$EXP" ] || EXP="$PWD/holding/scripts/assistant-explain.sh"
    exec bash "$EXP" "$@"
    ;;

  ask)
    FB="$PLUGIN_ROOT/hooks/assistant-feedback.sh"
    [ -x "$FB" ] || FB="$PWD/holding/scripts/assistant-feedback.sh"
    exec bash "$FB" --ask "$@"
    ;;

  answer)
    FB="$PLUGIN_ROOT/hooks/assistant-feedback.sh"
    [ -x "$FB" ] || FB="$PWD/holding/scripts/assistant-feedback.sh"
    exec bash "$FB" --answer "$@"
    ;;

  pending)
    FB="$PLUGIN_ROOT/hooks/assistant-feedback.sh"
    [ -x "$FB" ] || FB="$PWD/holding/scripts/assistant-feedback.sh"
    exec bash "$FB" --list
    ;;

  profile)
    FB="$PLUGIN_ROOT/hooks/assistant-feedback.sh"
    [ -x "$FB" ] || FB="$PWD/holding/scripts/assistant-feedback.sh"
    exec bash "$FB" --profile
    ;;

  decommission)
    DC="$PLUGIN_ROOT/hooks/assistant-decommission.sh"
    [ -x "$DC" ] || DC="$PWD/holding/scripts/assistant-decommission.sh"
    exec bash "$DC" "$@"
    ;;
  version|--version|-v)
    manifest="$PLUGIN_ROOT/.claude-plugin/plugin.json"
    if [ -f "$manifest" ] && command -v jq >/dev/null 2>&1; then
      jq -r '.version' "$manifest"
    else
      echo "unknown"
    fi
    ;;
  help|--help|-h|"")
    cat <<EOF
Sutra — operating system for building with AI

Usage: sutra <subcommand> [args]

Lifecycle:
  start                Activate Sutra in current project (the one command).
                       Onboards + enables telemetry + prints banner.
  status               Show install_id, project_id, queue depth, telemetry.
  update               Pull the latest plugin version from the marketplace.
  uninstall [--purge]  Remove the plugin; --purge also wipes ~/.sutra/.

Feedback (v2.0):
  feedback "<msg>"     Capture feedback locally at ~/.sutra/feedback/manual/.
                       Grants consent for auto-capture signals to persist.
                       Nothing transmitted — see ~/.sutra/PRIVACY.md.
  feedback --public "<msg>"
                       (v2.1) Opt-in GitHub issue post via gh CLI.
                       Requires confirmation; scrubbed before post.

Learn (v2.1 — PEDAGOGY charter):
  learn                List available lessons.
  learn <topic>        Print a lesson (depth / routing / charters / hooks / build-layer).
  learn --all          Print all 5 in order.

Security (v2.1 — SECURITY charter):
  sbom                 Generate SBOM (SHA256 per file) for integrity checks.

Power-user:
  push                 Manually push queued telemetry (auto-runs on Stop).
  permissions          Print paste-ready JSON allowlist for .claude/settings.local.json.
  install-shell-helpers  Add sutra-go / sutra-uninstall / sutra-reset
                       / sutra-status-global to your ~/.zshrc or ~/.bashrc.
  leak-audit           Scan plugin tree for brand strings (dev check).
  version              Print installed plugin version.

Inside Claude Code (slash commands):
  /core:start         Activate in current project
  /core:status        Local state
  /core:update        Pull latest plugin version
  /core:uninstall     Remove plugin
  /core:permissions   Print paste-ready allowlist
  /core:depth-check   Manual depth marker

Docs: https://github.com/sankalpasawa/sutra
EOF
    ;;
  *)
    echo "sutra: unknown subcommand '$SUBCMD'" >&2
    echo "Run 'sutra help' for usage." >&2
    exit 2
    ;;
esac
