{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "rootDir": "./lib",
    "outDir": "./lib",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "noUncheckedIndexedAccess": false
  },
  "include": ["lib/**/*"],
  "exclude": ["node_modules", "dist", "tests", "lib/**/*.test.ts"]
}


